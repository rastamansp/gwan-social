// Schema físico alinhado ao domínio em gwan-social.fixtures.json (schemaVersion 2).
// Migrations: Prisma. Ver docs/03-data-architecture/database-schema-physical.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id
  username     String   @unique
  email        String?  @unique
  displayName  String   @map("display_name")
  avatarUrl    String?  @map("avatar_url")
  headline     String?
  passwordHash String?  @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  postsAuthored Post[]         @relation("PostAuthor")
  comments      Comment[]
  ratingsGiven  Rating[]       @relation("RatingReviewer")
  ratingsRecv   Rating[]       @relation("RatingReviewee")
  friendsAsUser Friendship[]   @relation("FriendshipUser")
  friendsAsPeer Friendship[]   @relation("FriendshipFriend")
  postMentions  PostMention[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String    @map("token_hash")
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model Post {
  id             String   @id
  authorId       String   @map("author_id")
  author         User     @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Restrict)
  type           String
  title          String
  description    String
  createdAt      DateTime @map("created_at")
  visibility     String
  category       String
  location       Json?
  tags           Json
  isTrending     Boolean  @map("is_trending")
  isHighestRated Boolean  @map("is_highest_rated")

  media    PostMedia[]
  comments Comment[]
  ratings  Rating[]
  mentions PostMention[]

  @@map("posts")
}

model PostMedia {
  id       String @id
  postId   String @map("post_id")
  post     Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  type     String
  url      String
  alt      String?
  position Int

  @@map("post_media")
}

model Comment {
  id        String   @id
  postId    String   @map("post_id")
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  authorId  String   @map("author_id")
  author    User     @relation(fields: [authorId], references: [id], onDelete: Restrict)
  text      String
  createdAt DateTime @map("created_at")

  @@map("comments")
}

model Rating {
  id            String   @id
  reviewerId    String   @map("reviewer_id")
  reviewer      User     @relation("RatingReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)
  revieweeId    String   @map("reviewee_id")
  reviewee      User     @relation("RatingReviewee", fields: [revieweeId], references: [id], onDelete: Restrict)
  postId        String?  @map("post_id")
  post          Post?    @relation(fields: [postId], references: [id], onDelete: SetNull)
  value         Int
  comment       String
  createdAt     DateTime @map("created_at")
  contextType   String   @map("context_type")
  interactionId String?  @map("interaction_id")

  @@map("ratings")
}

model Friendship {
  userId       String @map("user_id")
  friendUserId String @map("friend_user_id")
  user         User   @relation("FriendshipUser", fields: [userId], references: [id], onDelete: Cascade)
  friend       User   @relation("FriendshipFriend", fields: [friendUserId], references: [id], onDelete: Cascade)
  status       String

  @@id([userId, friendUserId])
  @@map("friendships")
}

model PostMention {
  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@map("post_mentions")
}
