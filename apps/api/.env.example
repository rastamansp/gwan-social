# NestJS — variáveis lidas por @nestjs/config (ficheiro .env nesta pasta ao correr `npm run dev:api`)
PORT=4000

# PostgreSQL (Prisma) — obrigatório para `prisma migrate` / `prisma db seed`
# Exemplo local: postgresql://USER:PASSWORD@localhost:5432/gwan_social_dev
# Recomendado: ?connect_timeout=10 (segundos) para não ficar preso em rede/firewall
# DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/gwan_social_dev?connect_timeout=10
DATABASE_URL=
# Caminho opcional ao gwan-social.fixtures.json (API + `prisma db seed`: default `apps/web/.../gwan-social.fixtures.json`)
# FIXTURES_PATH=
# URL pública base no OpenAPI / links da raiz (default: http://localhost:<PORT>)
# PUBLIC_API_URL=http://localhost:4000
# Origens CORS (vírgula). Docker Compose pode usar Vite + Nginx, ex.:
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://127.0.0.1:5173

# JWT (obrigatório em produção: min. 32 caracteres). Em dev sem valor, usa segredo de desenvolvimento.
# JWT_SECRET=
# Tempo de vida do access token em segundos (ex.: 900 = 15 min)
# JWT_ACCESS_EXPIRES_SEC=900
# Tempo de vida do refresh token em segundos (ex.: 604800 = 7 dias)
# JWT_REFRESH_EXPIRES_SEC=604800

# Se true, `GET /me` sem `Authorization` devolve o utilizador do fixture (comportamento antigo). Se false, exige JWT.
# AUTH_FIXTURE_ME_FALLBACK=false

# --- Docker produção (docker-compose-production.yml + Traefik) ---
# Host público HTTPS da API (Host(...) no Traefik e PUBLIC_API_URL=https://<host>).
# GWAN_SOCIAL_API_HOST=api.social.gwan.com.br