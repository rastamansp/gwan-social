# Copiar para `.env` na raiz e ajustar (o `.env` não deve ser commitado).
# Usado por `docker compose -f docker-compose-production.yml` (substituição de variáveis).

# Domínio público da SPA — regra Traefik Host(`…`)
# URL base completa: https://social.gwan.com.br/
GWAN_SOCIAL_HOST=social.gwan.com.br

# Build-time Vite — URL base completa até `/api/v1` (obrigatório definir antes do build em produção)
# Dev local: http://localhost:4000/api/v1
# Produção (HTTPS), ex.: https://api.seudominio.com/api/v1
# VITE_API_URL=
# VITE_APP_NAME=Gwan Social
# VITE_APP_VERSION=1.0.0
